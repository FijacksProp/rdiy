# Neon PostgreSQL pooled connection string. Keep this server-side.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
RATE_LIMIT_SALT=replace-with-a-random-64-character-secret

# Resend is optional in local development. Records are still stored if it is absent.
RESEND_API_KEY=re_replace_with_resend_api_key
CONTACT_TO_EMAIL=rdiy.sl.org@gmail.com
RESEND_FROM_EMAIL=RDIY Website <onboarding@resend.dev>

# Comma-separated origins allowed to submit forms in addition to the current host.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Public instructions returned after a donation enquiry. Never put PINs, OTPs, or secrets here.
DONATION_INSTRUCTIONS=RDIY will contact you with verified mobile-money or bank-transfer instructions.
